# Copy to .env in this directory and fill in.
# Bun auto-loads .env from CWD, so run the adapter from adapters/discord/:
#   cd adapters/discord && bun bot.ts

# Bot token from https://discord.com/developers/applications
DISCORD_BOT_TOKEN=

# JSON map: Discord channel ID -> claude-multi-peer peer ID.
# Discover peer IDs by running `bun cli.ts peers` or by asking any running
# session to call the `whoami` tool.
# Example (two channels routed to two different sessions):
#   CLAUDE_PEERS_DISCORD_CHANNEL_MAP={"1234567890123456789":"abc12345","2222222222222222222":"def67890"}
CLAUDE_PEERS_DISCORD_CHANNEL_MAP={}

# Broker port (only override if you changed it in the broker itself)
# CLAUDE_PEERS_PORT=7899

# How often (ms) to check for peer -> Discord messages
# DISCORD_ADAPTER_POLL_MS=1500
